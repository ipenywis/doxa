# ─────────────────────────────────────────────────────────────────────────────
# AI Chat Agent
# ─────────────────────────────────────────────────────────────────────────────
# API key for the AI provider configured in src/settings/ai.ts
AI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Content Source
# ─────────────────────────────────────────────────────────────────────────────
# Where documentation MDX comes from at runtime. See src/settings/content.ts
# for full docs on each adapter.
#
#   vite   (default) — docs are bundled from src/contents/docs/ at build time.
#                      Zero external calls. Best for small docs.
#   github           — docs are fetched from a GitHub repo at runtime via the
#                      GitHub REST API. Content updates appear without redeploy.
#                      Best when docs live in a separate repo or are edited via
#                      the GitHub web UI.
#
# CONTENT_SOURCE=vite

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Adapter (only needed when CONTENT_SOURCE=github)
# ─────────────────────────────────────────────────────────────────────────────
# DOXA_GITHUB_OWNER=your-org
# DOXA_GITHUB_REPO=your-docs-repo
# DOXA_GITHUB_BRANCH=main
# DOXA_GITHUB_BASE_PATH=src/contents/docs

# Personal access token.
#   - Public repos: optional (but recommended — bumps rate limit from 60/hr
#     to 5000/hr).
#   - Private repos: required. Create a fine-grained token at
#     https://github.com/settings/tokens?type=beta with
#     "Contents: Read-only" permission on the docs repo.
# DOXA_GITHUB_TOKEN=

# In-memory cache TTL in seconds. Defaults to 300 (5 minutes). Lower =
# faster content updates, more API calls. Higher = fewer API calls, slower
# propagation.
# DOXA_GITHUB_CACHE_TTL=300

# ─────────────────────────────────────────────────────────────────────────────
# Debug
# ─────────────────────────────────────────────────────────────────────────────
# Set to "true" to log content-layer diagnostics at module load — rawModules
# memory footprint (file count, UTF-8 size, approx JS heap, % of Cloudflare
# workerd 128 MB limit). Useful for capacity planning when scaling docs.
# VITE_DEBUG_CONTENT=true

# ─────────────────────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────────────────────
# VITE_SITE_URL=https://your-site.com
# VITE_COMPANY_LINK=https://your-company.com

# ─────────────────────────────────────────────────────────────────────────────
# Open Source Badge
# ─────────────────────────────────────────────────────────────────────────────
# When set, footer renders a "Free and OpenSource" link with a GitHub icon
# pointing to this repo URL. Leave unset on user-deployed docs to hide the
# badge — it's only meant for our own official docs deployments.
# VITE_OPENSOURCE_REPO_URL=https://github.com/ipenywis/doxa
