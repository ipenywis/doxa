{
  "name": "rubix-documents",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "vite preview",
    "lint": "eslint --quiet",
    "lint:fix": "eslint --fix --quiet",
    "format": "pnpx prettier --write . --log-level warn",
    "format:check": "pnpx prettier --check .",
    "clean": "pnpm run lint:fix && pnpm run format && pnpm run format:check",
    "update": "pnpm update --latest --recursive && pnpm install && pnpm prune && pnpm dedupe && pnpm run clean",
    "generate-content-json": "ts-node scripts/content.ts",
    "generate-content-json:ide": "node -r esbuild-register scripts/content.ts",
    "generate:docs": "tsx scripts/docs-generator/generator.ts",
    "generate:docs:watch": "tsx scripts/docs-generator/generator.ts --watch",
    "prepare": "husky",
    "deploy": "vite build && pnpx wrangler deploy"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/ai": "0.8.1",
    "@tanstack/ai-anthropic": "0.7.0",
    "@tanstack/ai-grok": "0.6.2",
    "@tanstack/ai-openai": "0.7.1",
    "@tanstack/ai-openrouter": "0.6.6",
    "@tanstack/ai-react": "0.7.2",
    "@tanstack/react-router": "^1.93.0",
    "@tanstack/react-start": "^1.93.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "mdast": "^3.0.0",
    "mermaid": "^11.12.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-code-titles": "^1.2.1",
    "rehype-katex": "^7.0.1",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^4.4.1",
    "esbuild": "^0.27.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "remark-frontmatter": "^5.0.0",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": "^24.x"
  },
  "packageManager": "pnpm@10.25.0"
}