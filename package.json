{
  "name": "@doxahq/docs-template",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "exports": {
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    },
    "./content": {
      "types": "./src/lib/content/types.ts",
      "import": "./src/lib/content/types.ts"
    },
    "./components": {
      "types": "./src/runtime/mdx-components.ts",
      "import": "./src/runtime/mdx-components.ts"
    }
  },
  "scripts": {
    "dev": "pnpm run dev:cloudflare",
    "dev:cloudflare": "cross-env DOXA_DEPLOY_TARGET=cloudflare vite dev",
    "dev:vercel": "cross-env DOXA_DEPLOY_TARGET=vercel vite dev",
    "build": "pnpm run build:cloudflare",
    "build:cloudflare": "cross-env DOXA_DEPLOY_TARGET=cloudflare vite build",
    "build:docker": "cross-env DOXA_DEPLOY_TARGET=docker vite build",
    "build:vercel": "cross-env DOXA_DEPLOY_TARGET=vercel vite build",
    "start": "vite preview",
    "start:docker": "node .output/server/index.mjs",
    "lint": "pnpm exec eslint . --quiet",
    "lint:fix": "pnpm exec eslint . --fix --quiet",
    "format": "pnpm exec prettier --write . --log-level warn",
    "format:check": "pnpm exec prettier --check .",
    "typecheck": "pnpm exec tsc --noEmit --incremental false --pretty false",
    "test": "vitest run",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "clean": "pnpm run lint:fix && pnpm run format && pnpm run format:check",
    "update": "pnpm update --latest --recursive && pnpm install && pnpm prune && pnpm dedupe && pnpm run clean",
    "generate-content-json": "tsx src/scripts/content.ts",
    "generate-content-json:ide": "node -r esbuild-register src/scripts/content.ts",
    "generate:docs": "tsx scripts/docs-generator/generator.ts",
    "generate:docs:watch": "tsx scripts/docs-generator/generator.ts --watch",
    "prepare": "husky",
    "precommit": "pnpm exec lint-staged",
    "deploy": "pnpm run deploy:cloudflare",
    "deploy:cloudflare": "pnpm run build:cloudflare && pnpm run deploy:cloudflare:built",
    "deploy:cloudflare:built": "pnpm exec wrangler deploy -c dist/server/wrangler.json",
    "deploy:vercel": "vercel deploy --prod"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/ai": "0.8.1",
    "@tanstack/ai-anthropic": "0.7.0",
    "@tanstack/ai-grok": "0.6.2",
    "@tanstack/ai-openai": "0.7.1",
    "@tanstack/ai-openrouter": "0.6.6",
    "@tanstack/ai-react": "0.7.2",
    "@tanstack/react-router": "^1.93.0",
    "@tanstack/react-start": "^1.93.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.12.2",
    "minisearch": "^7.2.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-code-titles": "^1.2.1",
    "rehype-katex": "^7.0.1",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^4.4.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.2",
    "esbuild-register": "^3.6.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nitro": "3.0.260415-beta",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "remark-frontmatter": "^5.0.0",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vercel": "^51.3.0",
    "vitest": "^2.1.9",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "4.82.2"
  },
  "engines": {
    "node": "^24.x"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,cjs,mjs}": [
      "eslint --fix --quiet --no-warn-ignored",
      "prettier --write --ignore-unknown"
    ],
    "*.{json,jsonc,css,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
